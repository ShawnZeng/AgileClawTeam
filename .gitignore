# ─── Dependencies ─────────────────────────────────────────────────────────────
/node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js build output ─────────────────────────────────────────────────────
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# ─── Environment / secrets ────────────────────────────────────────────────────
.env*
!.env.local.example

# ─── Device auth keys (auto-generated by OpenClaw dashboard pairing) ──────────
.dashboard-device.json

# ─── Runtime work directories (generated during agent execution) ──────────────
/state/
/workarea/
/openclaw/workspaces/state/

# ─── Leftover dashboard/ directory (empty after restructure) ─────────────────
/dashboard/

# ─── Planning / developer notes not intended for repo ─────────────────────────
plan-agileMultiAgentSystem.prompt.md

# ─── Misc ──────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.vercel
/coverage
