# OpenClaw Gateway connection settings
# Copy this file to .env.local and fill in your values,
# then restart the dev server: npm run dev

# Gateway address (default: 127.0.0.1:18789)
OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789

# Gateway auth token — required if your openclaw.json configures gateway.auth.token
# Find it in ~/.openclaw/openclaw.json or ~/.openclaw/.env
# OPENCLAW_GATEWAY_TOKEN=your_token_here
